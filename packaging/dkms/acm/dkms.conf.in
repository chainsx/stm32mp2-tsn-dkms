PACKAGE_NAME="stm32mp2-tsn-acm"
PACKAGE_VERSION="@DKMS_VERSION@"
BUILT_MODULE_NAME[0]="acm"
BUILT_MODULE_LOCATION[0]="acm"
DEST_MODULE_LOCATION[0]="/updates/dkms"
MAKE[0]="sh ./build-with-edge-symvers.sh ${kernel_source_dir} /usr/src/stm32mp2-tsn-edge-@EDGE_DKMS_VERSION@"
CLEAN="make -C acm KDIR=${kernel_source_dir} ACM_DRIVER_VERSION= clean"
AUTOINSTALL="yes"
REMAKE_INITRD="yes"
BUILD_EXCLUSIVE_ARCH="^(aarch64|arm64)$"
