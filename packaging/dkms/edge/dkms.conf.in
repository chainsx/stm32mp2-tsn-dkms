PACKAGE_NAME="stm32mp257-tsn-edge"
PACKAGE_VERSION="@DKMS_VERSION@"
BUILT_MODULE_NAME[0]="edgx_pfm_lkm"
DEST_MODULE_LOCATION[0]="/updates/dkms"
# Mirrors OpenSTLinux kernel-module-edge: sched=fsc sid=sid.
MAKE[0]="make KDIR=${kernel_source_dir} sched=fsc sid=sid"
CLEAN="make clean"
AUTOINSTALL="yes"
REMAKE_INITRD="yes"
BUILD_EXCLUSIVE_ARCH="^(aarch64|arm64)$"
